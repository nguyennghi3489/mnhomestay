# Database
DATABASE_URL="postgresql://username:password@localhost:5432/localstay_db?schema=public"

# JWT Authentication
JWT_SECRET="your-super-secure-jwt-secret-key-here"
JWT_ACCESS_EXPIRES_IN="8h"
JWT_REFRESH_EXPIRES_IN="7d"

# API Configuration
PORT=3000
NODE_ENV="development"

# VNPay Integration
VNPAY_MERCHANT_ID="your-vnpay-merchant-id"
VNPAY_SECRET_KEY="your-vnpay-secret-key"
VNPAY_RETURN_URL="http://localhost:5173/payment/return"

# MoMo Integration
MOMO_PARTNER_CODE="your-momo-partner-code"
MOMO_ACCESS_KEY="your-momo-access-key"
MOMO_SECRET_KEY="your-momo-secret-key"

# Zalo Business API
ZALO_APP_ID="your-zalo-app-id"
ZALO_APP_SECRET="your-zalo-app-secret"

# Email Service (SendGrid)
SENDGRID_API_KEY="your-sendgrid-api-key"
FROM_EMAIL="noreply@localstay.vn"