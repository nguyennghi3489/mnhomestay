# LocalStay Backend Configuration

# Application
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL="postgresql://localstay:password@localhost:5432/localstay"

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h

# CORS
FRONTEND_URL=http://localhost:3000

# File uploads
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880